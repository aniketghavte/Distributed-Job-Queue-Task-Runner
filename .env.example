# API (apps/api)
PORT=3001
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Optional: require clients to send X-API-Key
# API_KEY=your-secret-key
# CORS_ORIGIN=http://localhost:3000

# Workers: optional simulated failures for retry/backoff demos
# SIMULATE_EMAIL_FAILURE=1

# Worker Prometheus sidecars (set in Docker Compose)
# WORKER_METRICS_PORT=9101

# Dashboard (apps/dashboard) — server-side proxy to API
# INTERNAL_API_URL=http://127.0.0.1:3001

# Browser WebSocket (must reach the API from the client)
# NEXT_PUBLIC_WS_URL=ws://127.0.0.1:3001/live
