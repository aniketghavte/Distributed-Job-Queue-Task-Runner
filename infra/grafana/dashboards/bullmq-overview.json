{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "showPoints": "never"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (queue, status) (rate(bullmq_jobs_processed_total[1m]))",
          "legendFormat": "{{queue}} — {{status}}",
          "refId": "A"
        }
      ],
      "title": "Job throughput (events/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
      "id": 2,
      "options": { "orientation": "horizontal", "showThresholdLabels": false },
      "targets": [
        {
          "expr": "bullmq_queue_depth",
          "legendFormat": "{{queue}} waiting",
          "refId": "A"
        }
      ],
      "title": "Queue depth (waiting)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, queue) (rate(bullmq_job_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{queue}}",
          "refId": "A"
        }
      ],
      "title": "Job duration p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum by (queue) (increase(bullmq_job_retries_total[1h]))",
          "legendFormat": "{{queue}} retries (1h)",
          "refId": "A"
        }
      ],
      "title": "Retries (increase over 1h)",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
